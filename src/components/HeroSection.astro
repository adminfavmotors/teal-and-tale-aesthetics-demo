---
import { content, getMediaById, type Locale, t } from "../lib/content";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const heroMedia = getMediaById(content.hero.mediaId);
const heroBadge = "Premium beauty \u00b7 Krakow, Zablocie";
const metricLabels = {
  pl: ["ocena gosci", "sredni czas odpowiedzi", "dni przyjec"],
  en: ["guest rating", "average reply time", "open days"],
};

function splitHeroTitle(title: string) {
  const commaIndex = title.indexOf(",");

  if (commaIndex === -1) {
    return title;
  }

  return `${title.slice(0, commaIndex + 1)}<br />${title.slice(commaIndex + 2)}`;
}
---

<section class="hero-section" id="top">
  <div class="container-shell hero-grid">
    <div class="hero-copy">
      <span class="eyebrow-pill" data-reveal>{heroBadge}</span>
      <h1 data-reveal style="--reveal-delay:0.1s;" set:html={splitHeroTitle(t(content.hero.title, locale))}></h1>
      <p class="hero-description" data-reveal style="--reveal-delay:0.2s;">
        {t(content.hero.description, locale)}
      </p>

      <div class="hero-actions" data-reveal style="--reveal-delay:0.3s;">
        <a class="button button--primary" href="#booking">{t(content.hero.primaryCta, locale)}</a>
        <a class="button button--ghost" href="#services">{t(content.hero.secondaryCta, locale)}</a>
      </div>

      <div class="hero-stats" data-reveal style="--reveal-delay:0.4s;">
        {
          content.hero.metrics.map((metric, index) => (
            <article class="hero-stat">
              <p class="hero-stat__value">{metric.value.replace(" h", "h")}</p>
              <p class="hero-stat__label">{metricLabels[locale][index]}</p>
            </article>
          ))
        }
      </div>
    </div>

    <div class="hero-media" data-reveal style="--reveal-delay:0.2s;">
      {
        heroMedia && (
          <img
            src={heroMedia.src}
            alt={t(heroMedia.alt, locale)}
            width={heroMedia.width}
            height={heroMedia.height}
            loading="eager"
            decoding="async"
          />
        )
      }
    </div>
  </div>
</section>
