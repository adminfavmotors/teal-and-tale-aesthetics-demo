---
import { content, type Locale, t } from "../lib/content";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="section-shell section-shell--dark" id="trust">
  <div class="container-shell">
    <div class="section-heading section-heading--dark" data-reveal>
      <p class="section-label section-label--dark">{t(content.trust.eyebrow, locale)}</p>
      <h2>{t(content.trust.title, locale)}</h2>
    </div>

    <div class="reviews-grid">
      {
        content.trust.platforms.map((platform, index) => (
          <article class="review-card" data-reveal style={`--reveal-delay:${index * 0.1}s;`}>
            <span class="review-card__platform">{platform.name}</span>
            <p class="review-card__rating">{platform.rating}</p>
            <p class="review-card__count">
              {platform.reviewCount} {locale === "pl" ? "opinii" : "reviews"}
            </p>
            <hr />
            <ul>
              {
                platform.notes.map((note) => <li>{t(note, locale)}</li>)
              }
            </ul>
            <a href={platform.link} target="_blank" rel="noreferrer">
              {locale === "pl" ? "Otworz profil" : "Open profile"}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
