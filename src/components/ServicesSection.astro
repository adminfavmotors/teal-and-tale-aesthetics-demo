---
import { content, formatDuration, formatPrice, getMediaById, type Locale, t } from "../lib/content";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const services = content.services.filter((service) => service.featured);
---

<section class="section-shell section-shell--base" id="services">
  <div class="container-shell">
    <div class="section-heading section-heading--center" data-reveal>
      <p class="section-label">Najczesciej wybierane</p>
      <h2>{t(content.servicesIntro.title, locale)}</h2>
    </div>

    <div class="services-grid">
      {
        services.map((service, index) => {
          const media = getMediaById(service.mediaId);

          return (
            <article class="service-card" data-reveal style={`--reveal-delay:${index * 0.1}s;`}>
              {
                media && (
                  <figure class="service-card__media">
                    <img
                      src={media.src}
                      alt={t(media.alt, locale)}
                      width={media.width}
                      height={media.height}
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )
              }

              <div class="service-card__meta">
                <span class="category-badge">{t(service.category, locale)}</span>
                <span>·</span>
                <span>{formatDuration(service.durationMin)}</span>
              </div>

              <h3>{t(service.name, locale)}</h3>
              <p class="service-card__description">{t(service.shortDescription, locale)}</p>

              <div class="service-card__footer">
                <p class="price">{formatPrice(service.price, service.currency, locale)}</p>
                <a class="button button--primary button--small" href={`/${locale}/?service=${service.id}#booking`}>
                  {locale === "pl" ? "Zarezerwuj" : "Reserve"}
                </a>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
