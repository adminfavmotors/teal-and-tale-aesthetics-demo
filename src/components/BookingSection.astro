---
import { content, formatDuration, formatPrice, type Locale, t } from "../lib/content";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const infoItems = {
  pl: ["12 dni w kalendarzu", "widzisz zajete sloty", "potwierdzenie przez WA/TG/email"],
  en: [
    "12 days visible in the calendar",
    "busy slots are visible at a glance",
    "confirmation via WA/TG/email",
  ],
};

const infoIcons = [
  '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 3v4M16 3v4M3 10h18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>',
  '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M12 7v5l3 2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H9l-4 3v-3H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
];

const channelIcons = {
  whatsapp:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 11.4A8.4 8.4 0 0 1 7.4 18.8L4 20l1.2-3.4A8.4 8.4 0 1 1 20 11.4Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 8.8c.1-.4.3-.5.5-.5h.8c.2 0 .4 0 .5.4l.6 1.6c.1.2 0 .4-.1.6l-.4.5c.4.8 1 1.4 1.8 1.8l.5-.4c.2-.1.4-.2.6-.1l1.6.6c.4.1.4.3.4.5v.8c0 .2-.1.4-.5.5-.5.2-1 .3-1.5.2-2.8-.7-5-2.9-5.7-5.7-.1-.5 0-1 .2-1.5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  telegram:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 4-3 15-5-4-3 3 .4-4.3L4 11 21 4Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="m10.4 13.7 7.2-7.2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  email:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="m4 7 8 6 8-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
} as const;

const categoryTabs = [
  { key: "nails", label: { pl: "Paznokcie", en: "Nails" } },
  { key: "pedicure", label: { pl: "Pedicure", en: "Pedicure" } },
  { key: "hair", label: { pl: "Wlosy", en: "Hair" } },
  { key: "brows", label: { pl: "Brwi & Rzesy", en: "Brows & Lashes" } },
];

function getCategoryKey(category: string) {
  const normalized = category.toLowerCase();

  if (normalized.includes("paz")) return "nails";
  if (normalized.includes("pedicure")) return "pedicure";
  if (normalized.includes("wlos")) return "hair";
  return "brows";
}

const serviceGroups = categoryTabs
  .map((tab) => ({
    ...tab,
    services: content.services.filter((service) => getCategoryKey(service.category.pl) === tab.key),
  }))
  .filter((group) => group.services.length > 0);

const submitLabel = locale === "pl" ? "Zarezerwuj wizyte →" : "Reserve your visit →";
---

<section class="section-shell section-shell--alt" id="booking">
  <div class="container-shell booking-grid">
    <div class="booking-copy">
      <p class="section-label" data-reveal>{t(content.booking.eyebrow, locale)}</p>
      <h2 data-reveal style="--reveal-delay:0.1s;">{t(content.booking.title, locale)}</h2>
      <p class="section-copy" data-reveal style="--reveal-delay:0.2s;">
        {t(content.booking.description, locale)}
      </p>

      <div class="booking-info-list">
        {
          infoItems[locale].map((item, index) => (
            <div class="booking-info-row" data-reveal style={`--reveal-delay:${index * 0.1}s;`}>
              <span class="booking-info-row__icon" set:html={infoIcons[index]}></span>
              <span>{item}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="booking-form-card" data-reveal>
      <form
        class="booking-form"
        data-booking-form
        data-locale={locale}
        data-api-endpoint="/api/leads"
        data-submit-label={submitLabel}
        data-submitting-label={t(content.booking.submittingLabel, locale)}
        data-success-message={t(content.booking.successMessage, locale)}
        data-error-message={t(content.booking.errorMessage, locale)}
        data-message-intro={t(content.booking.messageIntro, locale)}
        data-email-subject={t(content.booking.emailSubject, locale)}
        data-whatsapp={content.brand.contact.whatsApp}
        data-telegram={content.brand.contact.telegram}
        data-email={content.brand.contact.bookingEmail}
        data-calendar={JSON.stringify(content.booking.calendar)}
      >
        <div class="booking-form__group">
          <span class="field-label">{t(content.booking.fieldLabels.service, locale)}</span>

          <div class="service-tabs" role="tablist" aria-label={t(content.booking.fieldLabels.service, locale)}>
            {
              serviceGroups.map((group, index) => (
                <button
                  class:list={["service-tab", index === 0 && "is-active"]}
                  type="button"
                  data-service-tab={group.key}
                  aria-selected={index === 0 ? "true" : "false"}
                >
                  {group.label[locale]}
                </button>
              ))
            }
          </div>

          <div class="service-groups">
            {
              serviceGroups.map((group, groupIndex) => (
                <div
                  class:list={["service-group", groupIndex === 0 && "is-active"]}
                  data-service-group={group.key}
                >
                  {
                    group.services.map((service, serviceIndex) => (
                      <label class:list={["service-option", groupIndex === 0 && serviceIndex === 0 && "is-selected"]}>
                        <input
                          type="radio"
                          name="service"
                          value={service.id}
                          data-service-option-input={group.key}
                          data-service-name={t(service.name, locale)}
                          checked={groupIndex === 0 && serviceIndex === 0}
                          required
                        />
                        <span class="service-option__row">
                          <span class="service-option__title">{t(service.name, locale)}</span>
                          <span class="price">{formatPrice(service.price, service.currency, locale)}</span>
                        </span>
                        <span class="service-option__meta">{formatDuration(service.durationMin)}</span>
                      </label>
                    ))
                  }
                </div>
              ))
            }
          </div>
        </div>

        <div class="booking-form__group booking-form__fields">
          <label class="field">
            <span class="field-label">{t(content.booking.fieldLabels.name, locale)}</span>
            <input name="name" type="text" autocomplete="name" required />
          </label>

          <label class="field">
            <span class="field-label">{t(content.booking.fieldLabels.email, locale)}</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>

          <label class="field">
            <span class="field-label">{t(content.booking.fieldLabels.phone, locale)}</span>
            <input name="phone" type="tel" autocomplete="tel" required />
          </label>
        </div>

        <div class="booking-form__group booking-scheduler">
          <section class="scheduler-card">
            <div class="scheduler-card__header">
              <span class="field-label">{t(content.booking.calendar.labels.selectDate, locale)}</span>
              <span data-date-summary>{t(content.booking.calendar.labels.selectedDate, locale)}</span>
            </div>
            <div class="calendar-grid" data-date-grid></div>
            <input name="date" type="hidden" required data-date-input />
          </section>

          <section class="scheduler-card">
            <div class="scheduler-card__header">
              <span class="field-label">{t(content.booking.calendar.labels.selectTime, locale)}</span>
              <span data-time-summary>{t(content.booking.calendar.labels.selectedTime, locale)}</span>
            </div>
            <div class="timeslot-grid" data-time-grid></div>
            <input name="time" type="hidden" required data-time-input />
          </section>
        </div>

        <div class="booking-form__group">
          <span class="field-label">{t(content.booking.channelLabel, locale)}</span>
          <fieldset class="channel-grid">
            {
              content.booking.channels.map((channel, index) => (
                <label class:list={["channel-card", index === 0 && "is-selected"]}>
                  <input type="radio" name="channel" value={channel.id} checked={index === 0} data-channel-input />
                  <span class="channel-card__icon" set:html={channelIcons[channel.id]}></span>
                  <span class="channel-card__label">{channel.id === "whatsapp" ? "WA" : channel.id === "telegram" ? "TG" : "Email"}</span>
                </label>
              ))
            }
          </fieldset>
        </div>

        <div class="booking-form__group">
          <label class="field field--full">
            <span class="field-label">{t(content.booking.fieldLabels.notes, locale)}</span>
            <textarea
              name="notes"
              rows="4"
              placeholder={t(content.booking.notesPlaceholder, locale)}
            ></textarea>
          </label>
        </div>

        <div class="booking-form__group booking-consents">
          <label class="consent-row">
            <input type="checkbox" name="processingConsent" required />
            <span>{t(content.legal.consents.processing, locale)}</span>
          </label>

          <label class="consent-row">
            <input type="checkbox" name="contactConsent" required />
            <span>{t(content.legal.consents.contact, locale)}</span>
          </label>
        </div>

        <div class="booking-form__group">
          <button class="button button--primary booking-submit" type="submit" data-submit-button>
            <span data-submit-button-label>{submitLabel}</span>
          </button>
          <p class="booking-feedback" data-booking-feedback aria-live="polite"></p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const bookingForms = document.querySelectorAll("[data-booking-form]");

  type BookingLocale = "pl" | "en";
  type ContactChannel = "whatsapp" | "telegram" | "email";
  type FeedbackState = "pending" | "success" | "error";
  type CalendarConfig = {
    visibleDays: number;
    closedWeekdays: number[];
    blockedDayOffsets: number[];
    timeSlots: string[];
    busySlotsByDayOffset: Record<string, string[]>;
    labels: {
      selectDate: Record<BookingLocale, string>;
      selectTime: Record<BookingLocale, string>;
      selectedDate: Record<BookingLocale, string>;
      selectedTime: Record<BookingLocale, string>;
      unavailable: Record<BookingLocale, string>;
      fullyBooked: Record<BookingLocale, string>;
      available: Record<BookingLocale, string>;
    };
  };
  type CalendarDay = {
    offset: number;
    iso: string;
    date: Date;
    disabled: boolean;
    fullyBooked: boolean;
    busySlots: string[];
  };

  function getFieldLabels(locale: BookingLocale) {
    return {
      service: locale === "pl" ? "Usluga" : "Service",
      name: locale === "pl" ? "Imie" : "Name",
      email: "Email",
      phone: locale === "pl" ? "Telefon" : "Phone",
      date: locale === "pl" ? "Data" : "Date",
      time: locale === "pl" ? "Godzina" : "Time",
      notes: locale === "pl" ? "Notatka" : "Notes",
    };
  }

  function getLocaleCode(locale: BookingLocale) {
    return locale === "pl" ? "pl-PL" : "en-GB";
  }

  function toIsoDate(date: Date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");
    return `${year}-${month}-${day}`;
  }

  function parseCalendarConfig(form: HTMLFormElement): CalendarConfig {
    const parsed = JSON.parse(form.dataset.calendar ?? "{}");
    return {
      visibleDays: Number(parsed.visibleDays ?? 12),
      closedWeekdays: Array.isArray(parsed.closedWeekdays) ? parsed.closedWeekdays : [],
      blockedDayOffsets: Array.isArray(parsed.blockedDayOffsets) ? parsed.blockedDayOffsets : [],
      timeSlots: Array.isArray(parsed.timeSlots) ? parsed.timeSlots : [],
      busySlotsByDayOffset:
        parsed.busySlotsByDayOffset && typeof parsed.busySlotsByDayOffset === "object"
          ? parsed.busySlotsByDayOffset
          : {},
      labels: parsed.labels,
    };
  }

  function buildCalendarDays(config: CalendarConfig) {
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    return Array.from({ length: config.visibleDays }, (_, offset) => {
      const date = new Date(today);
      date.setDate(today.getDate() + offset);

      const busySlots = config.busySlotsByDayOffset[String(offset)] ?? [];
      const blocked = config.blockedDayOffsets.includes(offset);
      const closed = config.closedWeekdays.includes(date.getDay());
      const fullyBooked = busySlots.length >= config.timeSlots.length;

      return {
        offset,
        iso: toIsoDate(date),
        date,
        disabled: blocked || closed || fullyBooked,
        fullyBooked,
        busySlots,
      } satisfies CalendarDay;
    });
  }

  function formatCalendarButton(day: CalendarDay, locale: BookingLocale) {
    const weekday = new Intl.DateTimeFormat(getLocaleCode(locale), {
      weekday: "short",
    }).format(day.date);
    const dayNumber = new Intl.DateTimeFormat(getLocaleCode(locale), {
      day: "2-digit",
    }).format(day.date);
    const month = new Intl.DateTimeFormat(getLocaleCode(locale), {
      month: "short",
    }).format(day.date);

    return { weekday, dayNumber, month };
  }

  function formatSelectedDate(isoDate: string, locale: BookingLocale) {
    if (!isoDate) {
      return locale === "pl" ? "Brak wyboru" : "No date selected";
    }

    const [year, month, day] = isoDate.split("-").map(Number);
    const date = new Date(year, month - 1, day);

    return new Intl.DateTimeFormat(getLocaleCode(locale), {
      weekday: "short",
      day: "2-digit",
      month: "short",
    }).format(date);
  }

  function getMissingSlotMessage(locale: BookingLocale) {
    return locale === "pl" ? "Wybierz date i godzine." : "Please choose a date and time.";
  }

  function setFeedback(feedback: Element | null, state: FeedbackState, message: string) {
    if (!(feedback instanceof HTMLElement)) return;

    feedback.dataset.state = state;
    feedback.textContent = message;
  }

  function setSubmittingState(form: HTMLFormElement, isSubmitting: boolean) {
    const submitButton = form.querySelector("[data-submit-button]");
    const submitButtonLabel = form.querySelector("[data-submit-button-label]");

    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = isSubmitting;
    }

    if (submitButtonLabel instanceof HTMLElement) {
      submitButtonLabel.textContent = isSubmitting
        ? form.dataset.submittingLabel ?? ""
        : form.dataset.submitLabel ?? "";
    }
  }

  function buildMessage(form: HTMLFormElement, formData: FormData, locale: BookingLocale) {
    const labels = getFieldLabels(locale);
    const selectedService = form.querySelector("input[name='service']:checked");
    const serviceLabel =
      selectedService instanceof HTMLInputElement ? selectedService.dataset.serviceName ?? "" : "";

    const lines = [
      form.dataset.messageIntro ?? "",
      "",
      `${labels.service}: ${serviceLabel}`,
      `${labels.name}: ${String(formData.get("name") ?? "")}`,
      `${labels.email}: ${String(formData.get("email") ?? "")}`,
      `${labels.phone}: ${String(formData.get("phone") ?? "")}`,
      `${labels.date}: ${String(formData.get("date") ?? "")}`,
      `${labels.time}: ${String(formData.get("time") ?? "")}`,
    ];

    const notes = String(formData.get("notes") ?? "");
    if (notes) {
      lines.push(`${labels.notes}: ${notes}`);
    }

    return encodeURIComponent(lines.join("\n"));
  }

  function buildTarget(form: HTMLFormElement, channel: ContactChannel, message: string) {
    if (channel === "telegram") {
      return `https://t.me/${form.dataset.telegram}?text=${message}`;
    }

    if (channel === "email") {
      return `mailto:${form.dataset.email}?subject=${encodeURIComponent(
        form.dataset.emailSubject ?? "",
      )}&body=${message}`;
    }

    return `https://wa.me/${form.dataset.whatsapp}?text=${message}`;
  }

  function updateServiceVisualState(form: HTMLFormElement) {
    form.querySelectorAll(".service-option").forEach((option) => {
      const input = option.querySelector("input[name='service']");
      option.classList.toggle(
        "is-selected",
        input instanceof HTMLInputElement && input.checked,
      );
    });
  }

  function updateChannelVisualState(form: HTMLFormElement) {
    form.querySelectorAll(".channel-card").forEach((card) => {
      const input = card.querySelector("input[name='channel']");
      card.classList.toggle(
        "is-selected",
        input instanceof HTMLInputElement && input.checked,
      );
    });
  }

  function activateServiceGroup(form: HTMLFormElement, key: string) {
    form.querySelectorAll("[data-service-tab]").forEach((tab) => {
      if (!(tab instanceof HTMLButtonElement)) return;
      const isActive = tab.dataset.serviceTab === key;
      tab.classList.toggle("is-active", isActive);
      tab.setAttribute("aria-selected", isActive ? "true" : "false");
    });

    form.querySelectorAll("[data-service-group]").forEach((group) => {
      if (!(group instanceof HTMLElement)) return;
      const isActive = group.dataset.serviceGroup === key;
      group.classList.toggle("is-active", isActive);
    });

    const checkedInGroup = form.querySelector(
      `[data-service-group="${key}"] input[name='service']:checked`,
    );
    const firstInput = form.querySelector(
      `[data-service-group="${key}"] input[name='service']`,
    );

    if (!(checkedInGroup instanceof HTMLInputElement) && firstInput instanceof HTMLInputElement) {
      firstInput.checked = true;
    }

    updateServiceVisualState(form);
  }

  function applyRequestedService(form: HTMLFormElement) {
    const requestedService = new URL(window.location.href).searchParams.get("service");
    if (!requestedService) return;

    const input = form.querySelector(`input[name='service'][value="${requestedService}"]`);
    if (!(input instanceof HTMLInputElement)) return;

    input.checked = true;
    const key = input.dataset.serviceOptionInput ?? "";
    if (key) {
      activateServiceGroup(form, key);
    }
  }

  bookingForms.forEach((form) => {
    if (!(form instanceof HTMLFormElement)) return;

    const locale = form.dataset.locale === "en" ? "en" : "pl";
    const calendarConfig = parseCalendarConfig(form);
    const calendarDays = buildCalendarDays(calendarConfig);
    const dateGrid = form.querySelector("[data-date-grid]");
    const timeGrid = form.querySelector("[data-time-grid]");
    const dateInput = form.querySelector("[data-date-input]");
    const timeInput = form.querySelector("[data-time-input]");
    const dateSummary = form.querySelector("[data-date-summary]");
    const timeSummary = form.querySelector("[data-time-summary]");

    let selectedDate = "";
    let selectedTime = "";

    const firstTab = form.querySelector("[data-service-tab]");
    if (firstTab instanceof HTMLButtonElement && firstTab.dataset.serviceTab) {
      activateServiceGroup(form, firstTab.dataset.serviceTab);
    }

    applyRequestedService(form);
    updateChannelVisualState(form);

    form.querySelectorAll("[data-service-tab]").forEach((tab) => {
      if (!(tab instanceof HTMLButtonElement)) return;

      tab.addEventListener("click", () => {
        if (!tab.dataset.serviceTab) return;
        activateServiceGroup(form, tab.dataset.serviceTab);
      });
    });

    form.querySelectorAll("input[name='service']").forEach((input) => {
      input.addEventListener("change", () => updateServiceVisualState(form));
    });

    form.querySelectorAll("input[name='channel']").forEach((input) => {
      input.addEventListener("change", () => updateChannelVisualState(form));
    });

    function setDateSummary() {
      if (!(dateSummary instanceof HTMLElement)) return;
      dateSummary.textContent = `${calendarConfig.labels.selectedDate[locale]}: ${formatSelectedDate(selectedDate, locale)}`;
    }

    function setTimeSummary() {
      if (!(timeSummary instanceof HTMLElement)) return;
      timeSummary.textContent = `${calendarConfig.labels.selectedTime[locale]}: ${selectedTime || (locale === "pl" ? "Brak wyboru" : "No time selected")}`;
    }

    function renderTimeSlots() {
      if (!(timeGrid instanceof HTMLElement) || !(timeInput instanceof HTMLInputElement)) return;

      const activeDay = calendarDays.find((day) => day.iso === selectedDate);
      timeGrid.innerHTML = "";

      if (!activeDay || activeDay.disabled) {
        timeInput.value = "";
        selectedTime = "";
        setTimeSummary();
        return;
      }

      const availableSlots = calendarConfig.timeSlots.filter(
        (slot) => !activeDay.busySlots.includes(slot),
      );

      if (!availableSlots.includes(selectedTime)) {
        selectedTime = availableSlots[0] ?? "";
      }

      timeInput.value = selectedTime;

      calendarConfig.timeSlots.forEach((slot) => {
        const busy = activeDay.busySlots.includes(slot);
        const button = document.createElement("button");
        button.type = "button";
        button.className = "timeslot-chip";
        button.textContent = slot;

        if (busy) {
          button.disabled = true;
          button.dataset.state = "busy";
        } else {
          if (slot === selectedTime) {
            button.classList.add("is-selected");
          }

          button.addEventListener("click", () => {
            selectedTime = slot;
            timeInput.value = slot;
            renderTimeSlots();
            setTimeSummary();
          });
        }

        timeGrid.append(button);
      });

      setTimeSummary();
    }

    function renderCalendar() {
      if (!(dateGrid instanceof HTMLElement) || !(dateInput instanceof HTMLInputElement)) return;

      dateGrid.innerHTML = "";

      calendarDays.forEach((day) => {
        const button = document.createElement("button");
        const formatted = formatCalendarButton(day, locale);
        const stateLabel = day.disabled
          ? day.fullyBooked
            ? calendarConfig.labels.fullyBooked[locale]
            : calendarConfig.labels.unavailable[locale]
          : calendarConfig.labels.available[locale];

        button.type = "button";
        button.className = "calendar-chip";
        button.dataset.state = day.disabled
          ? day.fullyBooked
            ? "full"
            : "disabled"
          : "available";
        button.innerHTML = `
          <span class="calendar-chip__weekday">${formatted.weekday}</span>
          <strong>${formatted.dayNumber}</strong>
          <span class="calendar-chip__month">${formatted.month}</span>
          <small>${stateLabel}</small>
        `;

        if (day.disabled) {
          button.disabled = true;
        } else {
          if (day.iso === selectedDate) {
            button.classList.add("is-selected");
          }

          button.addEventListener("click", () => {
            selectedDate = day.iso;
            dateInput.value = day.iso;
            renderCalendar();
            renderTimeSlots();
            setDateSummary();
          });
        }

        dateGrid.append(button);
      });

      setDateSummary();
    }

    const firstAvailableDay = calendarDays.find((day) => !day.disabled);
    if (firstAvailableDay && dateInput instanceof HTMLInputElement) {
      selectedDate = firstAvailableDay.iso;
      dateInput.value = firstAvailableDay.iso;
    }

    renderCalendar();
    renderTimeSlots();

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const currentForm = event.currentTarget;
      if (!(currentForm instanceof HTMLFormElement)) return;

      const formData = new FormData(currentForm);
      const locale = currentForm.dataset.locale === "en" ? "en" : "pl";
      const channel = String(formData.get("channel") ?? "whatsapp") as ContactChannel;
      const feedback = currentForm.querySelector("[data-booking-feedback]");
      const message = buildMessage(currentForm, formData, locale);
      const target = buildTarget(currentForm, channel, message);

      if (!String(formData.get("date") ?? "") || !String(formData.get("time") ?? "")) {
        setFeedback(feedback, "error", getMissingSlotMessage(locale));
        return;
      }

      const payload = {
        serviceId: String(formData.get("service") ?? ""),
        customerName: String(formData.get("name") ?? ""),
        email: String(formData.get("email") ?? ""),
        phone: String(formData.get("phone") ?? ""),
        preferredDate: String(formData.get("date") ?? ""),
        preferredTime: String(formData.get("time") ?? ""),
        notes: String(formData.get("notes") ?? ""),
        preferredContactChannel: channel,
        locale,
        processingConsent: formData.get("processingConsent") === "on",
        contactConsent: formData.get("contactConsent") === "on",
      };

      const pendingWindow =
        channel === "email" ? null : window.open("", "_blank", "width=980,height=760");

      setSubmittingState(currentForm, true);
      setFeedback(feedback, "pending", currentForm.dataset.submittingLabel ?? "");

      try {
        const response = await fetch(currentForm.dataset.apiEndpoint ?? "/api/leads", {
          method: "POST",
          headers: {
            "content-type": "application/json",
            accept: "application/json",
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => null);

        if (!response.ok) {
          const firstFieldError = Object.values(result?.issues?.fieldErrors ?? {})
            .flat()
            .find(Boolean);

          throw new Error(
            firstFieldError ?? result?.message ?? currentForm.dataset.errorMessage ?? "Lead save failed.",
          );
        }

        setFeedback(feedback, "success", currentForm.dataset.successMessage ?? "");

        if (channel === "email") {
          window.location.href = target;
          return;
        }

        if (pendingWindow && !pendingWindow.closed) {
          pendingWindow.location.href = target;
          return;
        }

        window.open(target, "_blank", "noopener,noreferrer");
      } catch (error) {
        if (pendingWindow && !pendingWindow.closed) {
          pendingWindow.close();
        }

        setFeedback(
          feedback,
          "error",
          error instanceof Error
            ? error.message
            : currentForm.dataset.errorMessage ?? "Lead save failed.",
        );
      } finally {
        setSubmittingState(currentForm, false);
      }
    });
  });
</script>
